<UserControl x:Class="process_pipeline.Forms.ucCheckResult"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:process_pipeline.Forms"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="#333333" Foreground="#F0F0F0" SizeChanged="UserControl_SizeChanged" Loaded="UserControl_Loaded" MouseEnter="UserControl_MouseEnter">

  <!-- 替换 WinForms 的默认 Control 颜色，适配 CAD 深色 -->
  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/process_pipeline;component/Themes/App.xaml"/>
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>

  <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="5">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="391*"/>
      <ColumnDefinition Width="4*"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <!--高度由里面的控件（比如按钮）自动撑开-->
      <!--<RowDefinition Height="15.341"/>
      <RowDefinition Height="16.899"/>
      -->
      <!--WPF 里的 DockStyle.Fill！意思是占据所有剩余空间-->
      <!--
      <RowDefinition Height="60*"/>
      <RowDefinition Height="279*"/>
      <RowDefinition Height="21*"/>
      <RowDefinition Height="58*"/>-->
      <RowDefinition Height="38*"/>
      <RowDefinition Height="17*"/>
    </Grid.RowDefinitions>

    <!-- 顶部工具栏：使用 StackPanel，背景设为稍暗的颜色区分层次 -->
    <!--
    <Border Grid.Row="0" Background="#2D2D2D" BorderBrush="#111111" BorderThickness="0,0,0,1" Grid.RowSpan="2">
      <StackPanel Orientation="Horizontal" Margin="2">
         -->
    <!--应用刚才定义的样式：Style="{StaticResource CadFlatButton}"-->
    <!-- 
        <Button x:Name="btnRefresh" Content="刷新 🔄" Style="{StaticResource CadFlatButton}" Click="btnRefresh_Click"/>
        <Button x:Name="btnReversePolyline" Content="一键修复 🛠️" Style="{StaticResource CadFlatButton}" Click="btnReversePolyline_Click"/>
      </StackPanel>
    </Border>-->

    <!-- 数据表格 -->
    <DataGrid x:Name="dgvProblems" Grid.Row="0"
              AutoGenerateColumns="False" 
              CanUserAddRows="False" 
              IsReadOnly="True"
              BorderThickness="0" 
              GridLinesVisibility="All"
              SelectionUnit="CellOrRowHeader"
              SelectionMode="Extended"
              Background="{DynamicResource Brush.DataGrid.Row.Background}"
              RowBackground="{DynamicResource Brush.DataGrid.Row.Background}"
              AlternatingRowBackground="{DynamicResource Brush.DataGrid.AltRow.Background}"
              Foreground="{DynamicResource Brush.DataGrid.Text.Foreground}"
              HorizontalGridLinesBrush="{DynamicResource Brush.DataGrid.GridLine}"
              VerticalGridLinesBrush="{DynamicResource Brush.DataGrid.GridLine}"
              HeadersVisibility="All"
              VerticalScrollBarVisibility="Visible"
              HorizontalScrollBarVisibility="Visible"
              MouseDoubleClick="dgvProblems_MouseDoubleClick"
              SelectionChanged="dgvProblems_SelectionChanged"
              ClipboardCopyMode="None"
              PreviewMouseLeftButtonDown="dgvProblems_PreviewMouseLeftButtonDown"
              LoadingRow="dgvProblems_LoadingRow" Loaded="dgvProblems_Loaded" PreviewMouseRightButtonDown="dgvProblems_PreviewMouseRightButtonDown" Grid.ColumnSpan="2" Grid.RowSpan="2">

      <!-- ====================== 【新增：右键菜单】 ====================== -->
      <DataGrid.ContextMenu>
        <ContextMenu x:Name="ctxMenu">
          <!-- 菜单选项（可自由增删） -->
          <MenuItem x:Name="ctxZoomToExtent" Header="定位到CAD图纸" Click="CtxZoomToExtent_Click">
            <MenuItem.Icon>
              <!-- 可以使用矢量图标、图片或Path -->
              <Path Data="{StaticResource Icon_ZoomToExtent}" Stretch="Uniform" Width="16" Height="16" 
                      Fill="{DynamicResource Brush.CadBlue}"/>
            </MenuItem.Icon>
          </MenuItem>
          
          <MenuItem x:Name="ctxCopy" Header="复制" Click="CtxCopy_Click">
            <MenuItem.Icon>
              <!-- 可以使用矢量图标、图片或Path -->
              <Image Source="{StaticResource Icon_Copy}" Width="16" Height="16"/>
            </MenuItem.Icon>
           </MenuItem>

          <MenuItem x:Name="ctxSelection" Header="选择/取消" Click="CtxSelection_Click"/>

          <!--<MenuItem x:Name="ctxFix" Header="🛠️ 一键修复当前项" Click="CtxFix_Click"/>-->
          <Separator/>
          <!-- 分隔线 -->
          <MenuItem x:Name="ctxRefresh" Header="刷新" Click="CtxRefresh_Click"/>
        </ContextMenu>
      </DataGrid.ContextMenu>

      <DataGrid.CommandBindings>
        <CommandBinding Command="Copy" Executed="DataGrid_ExecuteCopy" />
      </DataGrid.CommandBindings>

      <!-- 【新增】：在 DataGrid 内部定义专属的单元格文字样式 -->
      <DataGrid.Resources>
        <!-- 1. 居中对齐样式 (作为默认主力) -->
        <Style x:Key="CenterText" TargetType="TextBlock">
          <Setter Property="HorizontalAlignment" Value="Center"/>
          <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- 2. 左对齐样式 (专门给描述列用) -->
        <Style x:Key="LeftText" TargetType="TextBlock">
          <Setter Property="HorizontalAlignment" Value="Left"/>
          <Setter Property="VerticalAlignment" Value="Center"/>
          <!-- 左对齐时，文字紧贴边框不好看，加 5 个像素的左边距 (Margin="左,上,右,下") -->
          <Setter Property="Margin" Value="5,0,0,0"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
          <Setter Property="Background" Value="{DynamicResource Brush.DataGrid.Header.Background}"/>
          <Setter Property="Foreground" Value="{DynamicResource Brush.DataGrid.Text.Foreground}"/>
          <Setter Property="FontWeight" Value="Bold"/>
          <Setter Property="FontSize" Value="14"/>
          <Setter Property="Height" Value="30"/>
          <Setter Property="Padding" Value="5,0"/>
          <Setter Property="BorderThickness" Value="0,0,1,1"/>
          <Setter Property="BorderBrush" Value="{DynamicResource Brush.DataGrid.GridLine}"/>
          <Setter Property="HorizontalContentAlignment" Value="Center"/>

          <!-- 关键：通过 Template 彻底解决箭头不可见问题 -->
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="DataGridColumnHeader">
                <Grid>
                  <!-- 主体背景和内容 -->
                  <Border x:Name="HeaderBorder" 
                              Background="{TemplateBinding Background}" 
                              BorderThickness="{TemplateBinding BorderThickness}" 
                              BorderBrush="{TemplateBinding BorderBrush}">
                    <Grid Margin="{TemplateBinding Padding}">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>

                      <ContentPresenter Grid.Column="0" 
                                                HorizontalAlignment="Center" 
                                                VerticalAlignment="Center"/>

                      <Path x:Name="SortArrow" 
                                    Grid.Column="1"
                                    Visibility="Collapsed" 
                                    Data="M 0,4 L 4,0 L 8,4 Z" 
                                    Fill="{TemplateBinding Foreground}" 
                                    Margin="5,0,2,0" 
                                    VerticalAlignment="Center" />
                    </Grid>
                  </Border>

                  <!-- 【关键新增】：左侧缩放抓手 (可选，通常不需要) -->
                  <!-- <Thumb x:Name="PART_LeftHeaderGripper" HorizontalAlignment="Left" Style="{StaticResource ColumnHeaderGripperStyle}"/> -->

                  <!-- 【关键新增】：右侧缩放抓手 (必须有它才能调宽) -->
                  <Thumb x:Name="PART_RightHeaderGripper" 
                             HorizontalAlignment="Right" 
                             Width="8" 
                             Cursor="SizeWE" 
                             Background="Transparent">
                    <Thumb.Template>
                      <ControlTemplate TargetType="Thumb">
                        <!-- 抓手本身是透明的，不影响视觉 -->
                        <Border Background="Transparent" />
                      </ControlTemplate>
                    </Thumb.Template>
                  </Thumb>
                </Grid>

                <ControlTemplate.Triggers>
                  <Trigger Property="SortDirection" Value="Ascending">
                    <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="SortArrow" Property="Data" Value="M 0,4 L 4,0 L 8,4 Z"/>
                  </Trigger>
                  <Trigger Property="SortDirection" Value="Descending">
                    <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="SortArrow" Property="Data" Value="M 0,0 L 4,4 L 8,0 Z"/>
                  </Trigger>
                  <!-- 悬停变色 -->
                  <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="HeaderBorder" Property="Background" Value="#555555"/>
                  </Trigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Style>

        <!-- 【新增】：最左侧行头样式，美化 -->
        <Style TargetType="DataGridRowHeader">
          <Setter Property="Width" Value="35"/>
          <Setter Property="MinWidth" Value="35"/>
          <Setter Property="Background" Value="{DynamicResource Brush.DataGrid.Header.Background}"/>
          <Setter Property="BorderBrush" Value="{DynamicResource Brush.DataGrid.GridLine}"/>
          <Setter Property="BorderThickness" Value="0,0,1,1"/>
          <Setter Property="HorizontalContentAlignment" Value="Center"/>
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="DataGridRowHeader">
                <Grid>
                  <Border x:Name="rowheaderborder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">

                    <!--显示行号-->
                    <TextBlock x:Name="rowheadertext"
                                 Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, Path=Header}" 
                                 VerticalAlignment="Center"
                                 HorizontalAlignment="Center"
                                 Foreground="{DynamicResource Brush.DataGrid.Text.Foreground}"/>
                  </Border>
                  <!--关键：在这里拦截点击事件用于选中整行-->
                  <!--<Thumb x:Name="PART_RowHeaderGripper" Style="{StaticResource {x:Static DataGrid.RowHeaderGripperStyle}}" />-->
                </Grid>

                <ControlTemplate.Triggers>
                  <!-- 注意：标签首字母必须大写 -->
                  <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                    <!-- 这里的 TargetName 必须对应上面的 x:Name -->
                    <Setter TargetName="rowheaderborder" Property="Background" Value="{DynamicResource Brush.DataGrid.SelectedRow.Background}"/>
                    <Setter TargetName="rowheadertext" Property="Foreground" Value="{DynamicResource Brush.DataGrid.SelectedText.Foreground}"/>
                  </DataTrigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Style>

        <!-- 重点：处理单元格选中颜色 -->
        <Style TargetType="DataGridCell">
          <Setter Property="BorderThickness" Value="0"/>
          <Style.Triggers>
            <!-- 选中时的颜色（无论是否有焦点） -->
            <Trigger Property="IsSelected" Value="True">
              <Setter Property="Background" Value="{DynamicResource Brush.DataGrid.SelectedRow.Background}"/>
              <Setter Property="Foreground" Value="{DynamicResource Brush.DataGrid.SelectedText.Foreground}"/>
            </Trigger>
          </Style.Triggers>
        </Style>

        <!-- 选中行的样式 -->
        <Style TargetType="DataGridRow">
          <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
              <Setter Property="Background" Value="{DynamicResource Brush.DataGrid.SelectedRow.Background}"/>
              <Setter Property="Foreground" Value="{DynamicResource Brush.DataGrid.SelectedText.Foreground}"/>
            </Trigger>
          </Style.Triggers>
          <Setter Property="MinHeight" Value="25" />
        </Style>
      </DataGrid.Resources>

      <DataGrid.Columns>
        <!-- 根据你的 ProblemItemViewModel 属性修改 Binding -->
        <!--<DataGridTextColumn Header="序号" Binding="{Binding NO}" Width="40"
                              ElementStyle="{StaticResource CenterText}"/>-->
        <DataGridTextColumn Header="管线ID" Binding="{Binding PipeId}" Width="80"
                              ElementStyle="{StaticResource CenterText}"/>
        <DataGridTextColumn Header="位置" Binding="{Binding Location}" Width="150"
                              ElementStyle="{StaticResource CenterText}"/>
        <DataGridTextColumn Header="问题描述" Binding="{Binding Description}" Width="350"
                              ElementStyle="{StaticResource LeftText}"/>
      </DataGrid.Columns>

      <DataGrid.RowStyle>
        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
          <!-- 只有真正点在“行”上才会触发 -->
          <EventSetter Event="PreviewMouseLeftButtonDown" Handler="DataGridRow_Click"/>
        </Style>
      </DataGrid.RowStyle>
    </DataGrid>
  </Grid>
</UserControl>
