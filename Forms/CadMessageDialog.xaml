<!-- 注意：在项目中请将此内容放入 .xaml 文件 -->
<Window x:Class="process_pipeline.Forms.CadMessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}" Width="420" 
        SizeToContent="Height" 
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/process_pipeline;component/Forms/Icons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="#F3F3F3" CornerRadius="5" BorderBrush="#CCCCCC" BorderThickness="0">
    <Grid>
      <Grid.RowDefinitions>
        <RowDefinition Height="40"/>
        <!-- 标题栏 -->
        <RowDefinition Height="*"/>
        <!-- 内容区 -->
        <RowDefinition Height="Auto"/>
        <!-- 按钮区 -->
      </Grid.RowDefinitions>

      <!-- 标题栏 -->
      <Border x:Name="HeaderBar" Grid.Row="0" CornerRadius="5,5,0,0" MouseLeftButtonDown="Header_MouseDown">
        <TextBlock x:Name="txtTitle" VerticalAlignment="Center" Margin="20,0" 
                           Foreground="White" FontWeight="Bold" FontSize="14"/>
      </Border>

      <!-- 内容区 -->
      <!--<StackPanel Grid.Row="1" Orientation="Horizontal" Margin="20,10">
        <Viewbox Width="40" Height="40" VerticalAlignment="Top" Margin="0,10,15,0">
          --><!-- 这里可以根据 type 切换图标，此处简化 --><!--
          <Path x:Name="iconPath" Fill="#2196F3" Data="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10,10-4.48,10-10S17.52,2,12,2zm1,15h-2v-6h2v6zm0-8h-2V7h2v2z"/>
        </Viewbox>
        <TextBlock x:Name="txtMessage" TextWrapping="Wrap" Width="330" VerticalAlignment="Center" FontSize="14" Foreground="#333333"/>
      </StackPanel>-->
      <Grid Grid.Row="1" Margin="25,15" MinHeight="60">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 图标：颜色和路径动态绑定 -->
        <Path x:Name="iconPath" Width="48" Height="48" Stretch="Uniform" VerticalAlignment="Top" Margin="0,5,15,0"/>

        <TextBlock x:Name="txtMessage" Grid.Column="1" TextWrapping="Wrap"
                   VerticalAlignment="Center" FontSize="12" 
                   LineHeight="20" 
                   Foreground="#444444"
                   LineStackingStrategy="BlockLineHeight"/>
      </Grid>

      <!-- 按钮区 -->
      <Border Grid.Row="2" Background="#F9F9F9" CornerRadius="0,0,5,5">
        <Button Content="确定" IsDefault="True" Width="90" Height="32" 
                        HorizontalAlignment="Right" Margin="0,0,20,5"
                        Click="Ok_Click" Cursor="Hand">
          <!-- 这里可以自定义 Button Style -->
        </Button>
      </Border>
    </Grid>
  </Border>
</Window>
