  <!-- 通用 MenuItem 样式 -->
  <Style x:Key="Style.MenuItem.Image" TargetType="MenuItem">
    <Setter Property="Icon">
      <Setter.Value>
        <!-- 用 ContentControl 解决多处显示同一个 Image 的问题 -->
        <ContentControl>
          <ContentControl.Template>
            <ControlTemplate>
              <Image Width="16" Height="16" Stretch="Uniform">
                <Image.Source>
                  <MultiBinding Converter="{StaticResource IconResourceKeyConverter}">
                    <!-- 1. 传 MenuItem 对象自己 -->
                    <Binding RelativeSource="{RelativeSource AncestorType=MenuItem}"/>
                    <!-- 2. 传 Tag -->
                    <Binding Path="Tag" RelativeSource="{RelativeSource AncestorType=MenuItem}"/>
                    <!-- 3. 传 IsEnabled -->
                    <Binding Path="IsEnabled" RelativeSource="{RelativeSource AncestorType=MenuItem}"/>
                  </MultiBinding>
                </Image.Source>
              </Image>
            </ControlTemplate>
          </ContentControl.Template>
        </ContentControl>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="Style.MenuItem.Path" TargetType="Path">
    <Setter Property="Width" Value="16"/>
    <Setter Property="Height" Value="16"/>
    <Setter Property="Stretch" Value="Uniform"/>
    <!-- 默认颜色 -->
    <Setter Property="Fill" Value="{DynamicResource Brush.CadBlue}"/>

    <Style.Triggers>
      <!-- 当所属的 MenuItem 被禁用时，Path 自动变色 -->
      <!-- 注意：这里使用 DataTrigger 绑定到宿主 MenuItem 的 IsEnabled -->
      <Trigger Property="IsEnabled" Value="False">
        <Setter Property="Fill" Value="{DynamicResource Brush.Icon.Disabled}"/>
      </Trigger>
    </Style.Triggers>
  </Style>

