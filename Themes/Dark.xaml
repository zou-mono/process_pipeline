<ResourceDictionary x:Class="process_pipeline.Forms.Themes"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="using:process_pipeline.Themes">
  
  <Color x:Key="PanelBackgroundColor">#383838</Color>
  <Color x:Key="HeaderBackground">#45464A</Color>
  <Color x:Key="RowBackground">#2D2D30</Color>
  <Color x:Key="AltRowBackground">#333337</Color>
  <Color x:Key="TextForeground">#DFDFDF</Color>
  <Color x:Key="GridLineColor">#555555</Color>
  <Color x:Key="SelectedRowBackground">#1E5E96</Color>

  <!-- DataGrid类(深色) -->
  <SolidColorBrush x:Key="Brush_PanelBackgroundColor" Color="{StaticResource PanelBackgroundColor}"/>
  <SolidColorBrush x:Key="Brush_HeaderBackground" Color="{StaticResource HeaderBackground}"/>
  <SolidColorBrush x:Key="Brush_RowBackground" Color="{StaticResource RowBackground}"/>
  <SolidColorBrush x:Key="Brush_AltRowBackground" Color="{StaticResource AltRowBackground}"/>
  <SolidColorBrush x:Key="Brush_TextForeground" Color="{StaticResource TextForeground}"/>
  <SolidColorBrush x:Key="Brush_GridLineColor" Color="{StaticResource GridLineColor}"/>
  <SolidColorBrush x:Key="Brush_SelectedRowBackground" Color="{StaticResource SelectedRowBackground}"/>
  
</ResourceDictionary>