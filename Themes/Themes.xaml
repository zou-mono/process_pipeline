<ResourceDictionary x:Class="process_pipeline.Forms.Themes"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="using:process_pipeline.Themes">

  <Color x:Key="White">#ffffff</Color>
  
  <Color x:Key="CadBlueColor">#0078D7</Color>
  <Color x:Key="WarningRedColor">#E81123</Color>
  <Color x:Key="SuccessGreenColor">#107C10</Color>

  <Color x:Key="ErrorColor">#F44336</Color>
  <Color x:Key="WarningColor">#FF9800</Color>
  <Color x:Key="InfoColor">#2196F3</Color>

  <Color x:Key="PanelBackgroundColor">#F0F0F0</Color>
  <Color x:Key="HeaderBackground">#45464A</Color>
  <Color x:Key="RowBackground">#2D2D30</Color>
  <Color x:Key="AltRowBackground">#333337</Color>
  <Color x:Key="TextForeground">#DFDFDF</Color>
  <Color x:Key="GridLineColor">#555555</Color>
  <Color x:Key="SelectedRowBackground">#1E5E96</Color>


  <!--<Color x:Key="InfoColor">#2196F3</Color>-->
  <SolidColorBrush x:Key="Brush_CadBlue" Color="{StaticResource CadBlueColor}" />
  <SolidColorBrush x:Key="Brush_WarningRed" Color="{StaticResource WarningRedColor}" />

  <!-- ============================================================ -->
  <!-- 2. 主题相关画刷 (DynamicResource) -->
  <!-- 这些 Key 的值会在后台代码切换主题时被替换 -->
  <!-- 这里先定义一套默认值（通常是深色模式） -->
  <!-- ============================================================ -->
  <!-- DataGrid类(深色) -->
  <SolidColorBrush x:Key="Brush_PanelBackgroundColor" Color="{StaticResource PanelBackgroundColor}"/>
  <SolidColorBrush x:Key="Brush_HeaderBackground" Color="{StaticResource HeaderBackground}"/>
  <SolidColorBrush x:Key="Brush_RowBackground" Color="{StaticResource RowBackground}"/>
  <SolidColorBrush x:Key="Brush_AltRowBackground" Color="{StaticResource AltRowBackground}"/>
  <SolidColorBrush x:Key="Brush_TextForeground" Color="{StaticResource TextForeground}"/>
  <SolidColorBrush x:Key="Brush_GridLineColor" Color="{StaticResource GridLineColor}"/>
  <SolidColorBrush x:Key="Brush_SelectedRowBackground" Color="{StaticResource SelectedRowBackground}"/>

  <!-- 对话框类 -->
  <SolidColorBrush x:Key="Brush_DialogErrorColor" Color="{StaticResource ErrorColor}"/>
  <SolidColorBrush x:Key="Brush_DialogWarningColor" Color="{StaticResource WarningColor}"/>
  <SolidColorBrush x:Key="Brush_DialogInfoColor" Color="{StaticResource InfoColor}"/>
  
  <!-- 背景类 -->
  <SolidColorBrush x:Key="Cad_WindowBackground" Color="#2D2D30" />
  <SolidColorBrush x:Key="Cad_PanelBackground" Color="#383838" />
  <SolidColorBrush x:Key="Cad_HeaderBackground" Color="#45464A" />

  <!-- 文字类 -->
  <SolidColorBrush x:Key="Cad_TextForeground" Color="#DFDFDF" />
  <SolidColorBrush x:Key="Cad_TextDisabled" Color="#808080" />

  <!-- 列表/表格类 -->
  <SolidColorBrush x:Key="Cad_GridLine" Color="#555555" />
  <SolidColorBrush x:Key="Cad_SelectedRow" Color="#1E5E96" />
</ResourceDictionary>
