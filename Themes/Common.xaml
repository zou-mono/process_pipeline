<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Color x:Key="White">#ffffff</Color>

  <Color x:Key="CadBlueColor">#003399</Color>
  <Color x:Key="WarningRedColor">#E81123</Color>
  <Color x:Key="SuccessGreenColor">#107C10</Color>

  <Color x:Key="ErrorColor">#F44336</Color>
  <Color x:Key="WarningColor">#FF9800</Color>
  <Color x:Key="InfoColor">#2196F3</Color>

  <Color x:Key="RowSelectedColor">#1E5E96</Color>

  <!--<Color x:Key="PanelBackgroundColor">#F0F0F0</Color>
  <Color x:Key="HeaderBackground">#45464A</Color>
  <Color x:Key="RowBackground">#2D2D30</Color>
  <Color x:Key="AltRowBackground">#333337</Color>
  <Color x:Key="TextForeground">#DFDFDF</Color>
  <Color x:Key="GridLineColor">#555555</Color>
  <Color x:Key="SelectedRowBackground">#1E5E96</Color>-->


  <!--<Color x:Key="InfoColor">#2196F3</Color>-->
  <SolidColorBrush x:Key="Brush.CadBlue" Color="{StaticResource CadBlueColor}" />
  <SolidColorBrush x:Key="Brush.WarningRed" Color="{StaticResource WarningRedColor}" />

  <SolidColorBrush x:Key="Brush.Icon.Disabled" 
                 Color="{DynamicResource {x:Static SystemColors.GrayTextColorKey}}" 
                 Opacity="0.8"/>


  <!-- ============================================================ -->
  <!-- 2. 主题相关画刷 (DynamicResource) -->
  <!-- 这些 Key 的值会在后台代码切换主题时被替换 -->
  <!-- 这里先定义一套默认值（通常是深色模式） -->
  <!-- ============================================================ -->
  <!-- 对话框类 -->
  <SolidColorBrush x:Key="Brush.DialogError" Color="{StaticResource ErrorColor}"/>
  <SolidColorBrush x:Key="Brush.DialogWarning" Color="{StaticResource WarningColor}"/>
  <SolidColorBrush x:Key="Brush.DialogInfo" Color="{StaticResource InfoColor}"/>
  
  <!-- 背景类 -->
  <SolidColorBrush x:Key="Cad_WindowBackground" Color="#2D2D30" />
  <SolidColorBrush x:Key="Cad_PanelBackground" Color="#383838" />
  <SolidColorBrush x:Key="Cad_HeaderBackground" Color="#45464A" />

  <!-- 文字类 -->
  <SolidColorBrush x:Key="Cad_TextForeground" Color="#DFDFDF" />
  <SolidColorBrush x:Key="Cad_TextDisabled" Color="#808080" />

  <!-- 列表/表格类 -->
  <SolidColorBrush x:Key="Cad_GridLine" Color="#555555" />
  <SolidColorBrush x:Key="Cad_SelectedRow" Color="{StaticResource RowSelectedColor}" />
</ResourceDictionary>
